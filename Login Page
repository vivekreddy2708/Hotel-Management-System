<%
String email=request.getParameter("email");
String password=request.getParameter("password");

if(email != null && password != null){
	Class.forName("com.mysql.cj.jdbc.Driver");
	Connection con=DriverManager.getConnection("jdbc:mysql://localhost:3306/hotel_Management?user=root&&password=12345678");
	PreparedStatement pr=con.prepareStatement("select * from users where email=?");
	pr.setString(1, email);
	ResultSet rs=pr.executeQuery();
	if(rs.next()){
		String pwd=rs.getString("password");
		if(pwd.equals(password)){
			session.setAttribute("userid", rs.getInt("id"));
			response.sendRedirect("homePage.jsp");
			
		}
		else{
			session.setAttribute("passwordError", "WrongPassword");
		}
	}
	else{
		session.setAttribute("emailError", "Wrong Email");
	}
	
	
	
}


%>
